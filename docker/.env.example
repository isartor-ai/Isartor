# Isartor Gateway Environment Configuration
#
# NOTE: The config crate uses separator("__"), so ALL env vars need
#       a double underscore after the ISARTOR prefix:
#         ISARTOR__KEY            → top-level field
#         ISARTOR__NESTED__FIELD  → nested struct field

# ── General ────────────────────────────────────────────────────────
ISARTOR__HOST_PORT="0.0.0.0:8080"
ISARTOR__GATEWAY_API_KEY="changeme"

# ── Layer 1 (Semantic Cache) ───────────────────────────────────────
ISARTOR__CACHE_MODE="both"
ISARTOR__EMBEDDING_MODEL="all-minilm"
ISARTOR__SIMILARITY_THRESHOLD="0.85"
ISARTOR__CACHE_TTL_SECS="300"
ISARTOR__CACHE_MAX_CAPACITY="10000"

# ── Layer 2 (Local SLM Triage) ─────────────────────────────────────
ISARTOR__LOCAL_SLM_URL="http://ollama:11434/api/generate"
ISARTOR__LOCAL_SLM_MODEL="llama3"

# ── Layer 3 (External LLM) ─────────────────────────────────────────
ISARTOR__LLM_PROVIDER="openai"
ISARTOR__EXTERNAL_LLM_MODEL="gpt-4o-mini"
ISARTOR__EXTERNAL_LLM_API_KEY=""

# ── Provider-specific Setup ────────────────────────────────────────
# OpenAI
# ISARTOR__EXTERNAL_LLM_URL="https://api.openai.com/v1/chat/completions"

# Anthropic
# ISARTOR__EXTERNAL_LLM_URL="https://api.anthropic.com/v1/messages"
# ISARTOR__ANTHROPIC_VERSION="2023-06-01"

# xAI / Grok
# ISARTOR__EXTERNAL_LLM_URL="https://api.x.ai/v1/chat/completions"

# Azure OpenAI
# ISARTOR__EXTERNAL_LLM_URL="https://your-resource.openai.azure.com"
# ISARTOR__AZURE_DEPLOYMENT_ID="your-deployment-name"
# ISARTOR__AZURE_API_VERSION="2024-08-01-preview"

# ── Logging ────────────────────────────────────────────────────────
RUST_LOG="isartor=info"
