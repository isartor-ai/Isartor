# =============================================================================
# Isartor — Azure OpenAI Environment
#
# Quick-start:
#
#   Embedded compose (llama.cpp sidecars):
#     cp .env.azure.example .env.full
#     # edit .env.full — fill in the three required values below
#     docker compose -f docker-compose.embedded.yml up --build
#
#   Azure compose (Ollama sidecars):
#     cp .env.azure.example .env
#     # edit .env — fill in the three required values below
#     docker compose -f docker-compose.azure.yml up --build
#
# Only the three values marked REQUIRED need to be set. Everything
# else has sensible defaults.
# =============================================================================

# ── Layer 3 — Azure OpenAI (REQUIRED) ──────────────────────────────
# NOTE: Double-underscore after ISARTOR is required by the config crate.
ISARTOR__LLM_PROVIDER=azure
ISARTOR__EXTERNAL_LLM_API_KEY=<your-azure-openai-key>
ISARTOR__EXTERNAL_LLM_URL=<https://your-resource.openai.azure.com>
ISARTOR__AZURE_DEPLOYMENT_ID=<your-deployment-name>

# ── Azure Optional ─────────────────────────────────────────────────
ISARTOR__EXTERNAL_LLM_MODEL=gpt-4o-mini
ISARTOR__AZURE_API_VERSION=2024-08-01-preview

# ── Gateway Auth ───────────────────────────────────────────────────
# ISARTOR__GATEWAY_API_KEY=changeme

# ── Logging ────────────────────────────────────────────────────────
# RUST_LOG=isartor=info
