# syntax=docker/dockerfile:1.4
# ============================================================================
# Dockerfile.embedded — Full-stack gateway with ONNX Runtime + fastembed
#
# Uses glibc (debian-slim) because ONNX Runtime does not ship pre-built
# binaries for musl targets.  Includes embedded ML inference features.
#
# Model: Qwen2-1.5B-Instruct (Q4_K_M, ~1.1 GB) downloaded at build time
# so the runtime image is fully self-contained.
#
# Build:
#   docker build -f docker/Dockerfile.embedded -t isartor:embedded .
#
# Used by:
#   docker/docker-compose.embedded.yml
# ============================================================================

# ── Stage 1: Model Fetcher ──────────────────────────────────────────────────
# Downloads the GGUF model once; Docker caches this layer so code changes
# don't trigger a 1 GB+ re-download.
FROM alpine:latest AS model-fetcher
RUN apk add --no-cache curl ca-certificates
WORKDIR /models
RUN curl -L --retry 5 --retry-delay 5 \
    -o qwen2-1_5b-instruct-q4_k_m.gguf \
    https://huggingface.co/Qwen/Qwen2-1.5B-Instruct-GGUF/resolve/main/qwen2-1_5b-instruct-q4_k_m.gguf

# ── Stage 2: Rust Builder ──────────────────────────────────────────────────
# Use rust:latest (Debian Trixie, glibc ≥ 2.39) because the ONNX Runtime
# prebuilt static library (ort-sys) references glibc 2.39 symbols
# (__isoc23_strtoll, __cxa_call_terminate).  Both stages must use Trixie.
FROM rust:latest AS builder

# cmake is needed by aws-lc-sys (rustls) and potentially by candle.
# pkg-config helps native crates discover system libraries.
RUN apt-get update \
    && apt-get install -y --no-install-recommends cmake g++ pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# ── Dependency caching layer ────────────────────────────────────────────────
# Copy only the manifests so dependency compilation is cached independently.
COPY Cargo.toml Cargo.lock* ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs \
    && cargo build --release \
    && rm -rf src

# ── Application build ──────────────────────────────────────────────────────
COPY src/ src/
RUN touch src/main.rs \
    && cargo build --release

# ── Stage 3: Slim runtime ──────────────────────────────────────────────────
# Must match the builder's glibc (Trixie ≥ 2.39) for ort-sys compatibility.
FROM debian:trixie-slim

# wget for health checks, ca-certificates for TLS to Hugging Face / Azure.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates wget \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/isartor /usr/local/bin/isartor

# Copy GGUF model from the fetcher stage so the image is self-contained.
RUN mkdir -p /usr/share/isartor/models
COPY --from=model-fetcher /models/qwen2-1_5b-instruct-q4_k_m.gguf /usr/share/isartor/models/qwen2-1_5b-instruct-q4_k_m.gguf
ENV ISARTOR__EMBEDDED__MODEL_PATH=/usr/share/isartor/models/qwen2-1_5b-instruct-q4_k_m.gguf

LABEL org.opencontainers.image.title="isartor"
LABEL org.opencontainers.image.description="Isartor AI Gateway — embedded inference (ONNX + fastembed + Qwen2-1.5B)"

ENV ISARTOR_HOST_PORT=0.0.0.0:8080
EXPOSE 8080

# Run as non-root.
RUN groupadd -r isartor && useradd -r -g isartor -m isartor

# fastembed downloads ONNX model files on first run.
# hf-hub downloads tokenizer.json on first run.
# Create writable cache directories owned by the non-root user.
RUN mkdir -p /home/isartor/.fastembed_cache /home/isartor/.cache/huggingface \
    && chown -R isartor:isartor /home/isartor
ENV FASTEMBED_CACHE_DIR=/home/isartor/.fastembed_cache

USER isartor

ENTRYPOINT ["isartor"]
